here we find out that is there is any duplicate present in the Array name nums or not
here is the solution of it:-
class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
       sort(nums.begin(), nums.end());

        for(int i = 1; i < nums.size(); i++) {
            if(nums[i] == nums[i - 1])
                return true;
        }

        return false;
    }
};
