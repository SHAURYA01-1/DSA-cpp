here is the 1st brute force solution:-
class Solution {
public:
    int majorityElement(vector<int>& nums) {

        int n = nums.size();

        for(int i = 0; i < n; i++) {

            int count = 0;

            for(int j = 0; j < n; j++) {

                if(nums[i] == nums[j]) {
                    count++;
                }

            }

            if(count > n/2) {
                return nums[i];
            }

        }

        return -1;
    }
};
Here is the better solution of it Moore's Voting Algorithm:-
class Solution {
public:
    int majorityElement(vector<int>& nums) {

        int count = 0;
        int candidate = 0;

        for(int num : nums) {

            if(count == 0)
                candidate = num;

            if(num == candidate)
                count++;
            else
                count--;
        }

        return candidate;
    }
};
